SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=sqlite:///./app.db
# mock | openai | lmstudio
AI_PROVIDER=mock
# Only required when AI_PROVIDER=openai
OPENAI_API_KEY=
# Only required when AI_PROVIDER=openai
OPENAI_MODEL=
# To use LM Studio instead, set AI_PROVIDER=lmstudio and configure:
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=nvidia.nemotron-mini-4b-instruct
# Dummy value is fine for LM Studio's OpenAI-compatible API.
LMSTUDIO_API_KEY=lm-studio
